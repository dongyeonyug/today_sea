# ==============================================================================
#  오늘의 바다 (Today's Sea) — 환경변수 예시
#  이 파일을 복사해 `.env.local` (Next.js 규칙) 또는 `.env` 로 만들고 값을 채우세요.
#  ⚠️  실제 키가 담긴 .env / .env.local 은 절대 커밋하지 마세요 (.gitignore 처리됨).
#
#  ※ 아래 링크는 2026-07-18 기준 실제 접속 확인을 거친 주소입니다.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1) Claude API — 챗봇 해설 (자연어 질문 → 맞춤 안전 답변)
#    발급: https://console.anthropic.com/  →  Settings → API Keys → Create Key
#    형식: sk-ant-...
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ------------------------------------------------------------------------------
# 2) 공공데이터포털 통합 인증키 (data.go.kr)  ★ 이 프로젝트의 핵심 키
#    하나의 인증키로 아래 여러 API를 씁니다. 단, API별로 각각 [활용신청]을 눌러야 합니다.
#
#    ▶ 가장 안전한 발급 경로 (검색으로 접근):
#      https://www.data.go.kr/tcs/dss/selectDataSetList.do?keyword=국립해양조사원
#      → 로그인/회원가입 → 필요한 API에서 [활용신청]
#      → 마이페이지 > 데이터활용 > 인증키 확인 (일반 인증키, Decoding/Encoding 둘 다 확보 권장)
#
#    ▶ 활용신청할 API (검색창 키워드 → 해당 항목 신청):
#      · "국립해양조사원 생활해양예보지수"  (해수욕지수·갯벌체험지수)
#          지점목록(확인됨): https://www.data.go.kr/data/15145389/fileData.do
#      · "국립해양조사원 조석예보"          (간조·만조 시각, 조위)   [검색으로 접근 권장]
#      · "기상청 기상특보 조회서비스"        (풍랑·강풍·호우 등 12종)
#          확인됨: https://www.data.go.kr/data/15000415/openapi.do
#
#    ※ 승인은 보통 자동(즉시)~1일. 개발계정 트래픽 제한(일 1,000~10,000건) 확인.
# ------------------------------------------------------------------------------
DATA_GO_KR_SERVICE_KEY=

# ------------------------------------------------------------------------------
# 3) open-meteo Marine API — 파고/수온/풍속/풍향/해류 (예보, 최대 16일)
#    ✅ 키 불필요 (비상업·저트래픽 무료). 비워두어도 동작합니다.
#    상업용 대량 호출 시에만 유료 API 키가 필요합니다.
#    문서(확인됨): https://open-meteo.com/en/docs/marine-weather-api
# ------------------------------------------------------------------------------
OPEN_METEO_API_KEY=

# ------------------------------------------------------------------------------
# 4) (선택) 국립해양조사원 자체 포털 — 바다누리/개방海
#    조석·조위는 위 (2) data.go.kr 로 통합 발급되므로 보통 불필요합니다.
#    실시간 조위 등 자체 포털만의 항목이 필요할 때만 사용하세요.
#    공식 안내(확인됨): https://www.khoa.go.kr/kcom/cnt/selectContentsPage.do?cntId=11501000
#    생활해양예보지수 오픈API 조회(확인됨):
#      https://khoa.go.kr/oceandata/openapi/odmi/odmiApiViewData.do?apiId=SV_AP_01_007
# ------------------------------------------------------------------------------
KHOA_OPENAPI_KEY=

# ------------------------------------------------------------------------------
#  앱 설정
# ------------------------------------------------------------------------------
# 기상청 이안류 예측은 주요 8개 해수욕장(해운대·송정·임랑 등)만 제공 → 지원 지점 한정
NEXT_PUBLIC_APP_NAME=오늘의 바다
